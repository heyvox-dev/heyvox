+# ---------------------------------------------------------------------------
+# Hush (Chrome extension) integration
+# ---------------------------------------------------------------------------
+
+_HUSH_SOCK = "/tmp/hush.sock"
+
+
+def _hush_command(action: str) -> dict | None:
+    """Send a command to the Hush Chrome extension via Unix socket.
+
+    Returns the parsed response dict, or None if Hush is unavailable.
+    """
+    if not os.path.exists(_HUSH_SOCK):
+        return None
+    try:
+        sock = _socket.socket(_socket.AF_UNIX, _socket.SOCK_STREAM)
+        sock.settimeout(3.0)
+        sock.connect(_HUSH_SOCK)
+        sock.sendall(json.dumps({"action": action}).encode() + b"\n")
+        data = b""
+        while True:
+            chunk = sock.recv(4096)
+            if not chunk:
+                break
+            data += chunk
+            if b"\n" in data:
+                break
+        sock.close()
+        resp = json.loads(data)
+        return resp if "error" not in resp else None
+    except (OSError, json.JSONDecodeError, ValueError):
+        return None
+
