#!/bin/bash
# Herald — TTS orchestration CLI
# Usage: herald <command> [args...]

set -euo pipefail

# Resolve symlinks to find the real script location
_self="$0"
while [ -L "$_self" ]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
unset _self _dir
source "${SCRIPT_DIR}/../lib/config.sh"

VERSION="0.1.0"

herald_ensure_dirs

kill_current_playback() {
  if [ -f "$HERALD_PLAYING_PID" ]; then
    kill "$(cat "$HERALD_PLAYING_PID")" 2>/dev/null || true
    rm -f "$HERALD_PLAYING_PID"
  fi
  pkill -f "afplay.*/tmp/herald" 2>/dev/null || true
}

cmd_speak() {
  local text="${*:-}"
  if [ -z "$text" ]; then
    text=$(cat)
  fi
  if [ -z "$text" ] || [ ${#text} -lt 5 ]; then
    echo "Usage: herald speak <text>"
    exit 1
  fi

  herald_is_muted && { echo "Muted"; exit 0; }
  herald_is_paused && { echo "Paused"; exit 0; }

  local _ts="${EPOCHREALTIME//.}"
  [ -z "$_ts" ] && _ts=$(python3 -c "import time;print(int(time.time()*1000000))" 2>/dev/null || date +%s)
  local raw_file="/tmp/herald-raw-$$.$_ts.txt"
  echo "<tts>${text}</tts>" > "$raw_file"

  export TTS_LABEL
  TTS_LABEL=$(herald_get_label "${CONDUCTOR_WORKSPACE_NAME:-}")

  nohup bash "${HERALD_HOME}/lib/worker.sh" "$raw_file" </dev/null >/dev/null 2>&1 &
  echo "Queued"
}

cmd_pause() {
  touch "$HERALD_PAUSE_FLAG"
  kill_current_playback
  herald_log "PAUSE: called by $(ps -o comm= -p $PPID 2>/dev/null || echo 'unknown') (ppid=$PPID)"
  echo "Paused"
}

cmd_resume() {
  local was_paused=false
  [ -f "$HERALD_PAUSE_FLAG" ] && was_paused=true
  rm -f "$HERALD_PAUSE_FLAG"
  herald_log "RESUME: called by $(ps -o comm= -p $PPID 2>/dev/null || echo 'unknown') (ppid=$PPID) was_paused=$was_paused"
  echo "Resumed"
}

cmd_skip() {
  kill_current_playback
  echo "Skipped"
}

cmd_stop() {
  kill_current_playback
  rm -f "$HERALD_QUEUE_DIR"/*.wav 2>/dev/null || true
  echo "Stopped"
}

cmd_mute() {
  if herald_is_muted; then
    rm -f "$HERALD_MUTE_FLAG"
    echo "Unmuted"
  else
    touch "$HERALD_MUTE_FLAG"
    kill_current_playback
    rm -f "$HERALD_QUEUE_DIR"/*.wav 2>/dev/null || true
    echo "Muted"
  fi
}

cmd_status() {
  local queue_count hold_count playing muted paused mode ambient
  queue_count=$(find "$HERALD_QUEUE_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | wc -l | tr -d ' ')
  hold_count=$(find "$HERALD_HOLD_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | wc -l | tr -d ' ')
  playing="no"
  [ -f "$HERALD_PLAYING_PID" ] && kill -0 "$(cat "$HERALD_PLAYING_PID")" 2>/dev/null && playing="yes"
  muted="no"
  herald_is_muted && muted="yes"
  paused="no"
  herald_is_paused && paused="yes"
  mode="narrate"
  [ -f "$HERALD_MODE_FILE" ] && mode=$(cat "$HERALD_MODE_FILE" 2>/dev/null)
  ambient="off"
  [ -f "$HERALD_AMBIENT_FLAG" ] && ambient="on"
  local voice="${KOKORO_VOICE:-auto}"

  echo "Queue: $queue_count | Held: $hold_count | Playing: $playing | Muted: $muted | Paused: $paused | Mode: $mode | Voice: $voice | Ambient: $ambient"
}

cmd_queue() {
  echo "=== Queue ==="
  find "$HERALD_QUEUE_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | sort | while read f; do
    echo "  $(basename "$f")"
  done
  echo "=== Held ==="
  find "$HERALD_HOLD_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | sort | while read f; do
    echo "  $(basename "$f")"
  done
  local qc hc
  qc=$(find "$HERALD_QUEUE_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | wc -l | tr -d ' ')
  hc=$(find "$HERALD_HOLD_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | wc -l | tr -d ' ')
  echo "Total: $qc queued, $hc held"
}

cmd_next() {
  touch "$HERALD_PLAY_NEXT"
  local count
  count=$(find "$HERALD_HOLD_DIR" -maxdepth 1 -name '*.wav' 2>/dev/null | wc -l | tr -d ' ')
  echo "Playing next ($count pending)"
}

cmd_replay() {
  local count="${1:-1}"
  local files
  files=$(find "$HERALD_HISTORY_DIR" -maxdepth 1 -name '*.wav' -exec stat -f '%m %N' {} + 2>/dev/null | sort -rn | head -"$count" | cut -d' ' -f2-)
  if [ -z "$files" ]; then
    echo "No history"
    exit 0
  fi
  echo "Replaying last $count..."
  echo "$files" | tail -r | while read f; do
    afplay "$f" 2>/dev/null
  done
}

cmd_mode() {
  local current="narrate"
  [ -f "$HERALD_MODE_FILE" ] && current=$(cat "$HERALD_MODE_FILE" 2>/dev/null)
  if [ "$current" = "narrate" ]; then
    echo "notify" > "$HERALD_MODE_FILE"
    echo "Mode: notify"
  else
    echo "narrate" > "$HERALD_MODE_FILE"
    echo "Mode: narrate"
  fi
}

cmd_voice() {
  local requested="${1:-}"
  if [ -z "$requested" ] || [ "$requested" = "auto" ]; then
    unset KOKORO_VOICE
    echo "Voice: auto (mood-based)"
  else
    export KOKORO_VOICE="$requested"
    echo "Voice: $requested"
  fi
}

cmd_ambient() {
  local event="${1:-}"
  if [ -z "$event" ]; then
    if [ -f "$HERALD_AMBIENT_FLAG" ]; then
      rm -f "$HERALD_AMBIENT_FLAG"
      echo "Ambient: off"
    else
      touch "$HERALD_AMBIENT_FLAG"
      echo "Ambient: on"
      bash "${HERALD_HOME}/modes/ambient.sh" complete
    fi
  else
    bash "${HERALD_HOME}/modes/ambient.sh" "$event"
  fi
}

cmd_recap() {
  bash "${HERALD_HOME}/modes/recap.sh"
  echo "Playing recap..."
}

cmd_greeting() {
  bash "${HERALD_HOME}/modes/greeting.sh"
}

cmd_notify() {
  bash "${HERALD_HOME}/modes/notify.sh"
}

cmd_cleanup() {
  bash "${HERALD_HOME}/modes/cleanup.sh"
}

cmd_daemon() {
  local subcmd="${1:-status}"
  case "$subcmd" in
    start)
      herald_ensure_dirs
      if ! kill -0 "$(cat "$HERALD_ORCH_PID" 2>/dev/null)" 2>/dev/null; then
        if mkdir /tmp/herald-orch-launch.lock 2>/dev/null; then
          if ! kill -0 "$(cat "$HERALD_ORCH_PID" 2>/dev/null)" 2>/dev/null; then
            nohup bash "${HERALD_HOME}/lib/orchestrator.sh" </dev/null >/dev/null 2>&1 &
            echo "Orchestrator started"
          else
            echo "Orchestrator already running"
          fi
          rm -rf /tmp/herald-orch-launch.lock
        else
          echo "Orchestrator launch in progress"
        fi
      else
        echo "Orchestrator already running"
      fi
      if [ -S "$KOKORO_DAEMON_SOCK" ] && kill -0 "$(cat "$KOKORO_DAEMON_PID" 2>/dev/null)" 2>/dev/null; then
        echo "Kokoro daemon already running"
      else
        nohup "$KOKORO_DAEMON_PYTHON" "$KOKORO_DAEMON_SCRIPT" </dev/null >>"$HERALD_DEBUG_LOG" 2>&1 &
        echo "Kokoro daemon starting..."
      fi
      ;;
    stop)
      if [ -f "$HERALD_ORCH_PID" ]; then
        kill "$(cat "$HERALD_ORCH_PID")" 2>/dev/null || true
        rm -f "$HERALD_ORCH_PID"
        echo "Orchestrator stopped"
      fi
      rm -rf "$HERALD_ORCH_LOCK"
      if [ -f "$KOKORO_DAEMON_PID" ]; then
        kill "$(cat "$KOKORO_DAEMON_PID")" 2>/dev/null || true
        rm -f "$KOKORO_DAEMON_PID" "$KOKORO_DAEMON_SOCK"
        echo "Kokoro daemon stopped"
      fi
      ;;
    status)
      local orch_status="stopped" kokoro_status="stopped"
      kill -0 "$(cat "$HERALD_ORCH_PID" 2>/dev/null)" 2>/dev/null && orch_status="running"
      [ -S "$KOKORO_DAEMON_SOCK" ] && kill -0 "$(cat "$KOKORO_DAEMON_PID" 2>/dev/null)" 2>/dev/null && kokoro_status="running"
      echo "Orchestrator: $orch_status | Kokoro: $kokoro_status"
      ;;
    *)
      echo "Usage: herald daemon start|stop|status"
      ;;
  esac
}

cmd_help() {
  cat <<'HELP'
Herald — TTS orchestration service

Usage: herald <command> [args...]

Playback:
  speak <text>     Generate TTS and enqueue (text from args or stdin)
  play <text>      Alias for speak
  pause            Pause playback (for Vox integration)
  resume           Resume playback
  skip             Skip current, play next
  stop             Stop all, clear queue
  mute             Toggle mute on/off
  next             Play next held message

Configuration:
  mode             Toggle narrate/notify mode
  voice [name]     Set voice (or 'auto' for mood-based)
  ambient [event]  Toggle ambient sounds, or play specific event

Info:
  status           Show pipeline status
  queue            Show queued messages
  replay [n]       Replay last N messages

Sessions:
  greeting         Quick time-aware greeting
  recap            Session recap with git context
  notify           Handle notification (reads stdin)
  cleanup          Session cleanup

Daemons:
  daemon start     Start orchestrator + Kokoro
  daemon stop      Stop daemons
  daemon status    Show daemon status

Diagnostics:
  violations       Show TTS-during-recording violations
  log [n]          Show last N lines of debug log (default 30)

Other:
  version          Show version
  help             Show this help
HELP
}

cmd_violations() {
  if [ ! -f "$HERALD_VIOLATIONS_LOG" ]; then
    echo "No violations recorded."
    return
  fi
  local count
  count=$(grep -c "^\\[" "$HERALD_VIOLATIONS_LOG" 2>/dev/null || echo 0)
  echo "=== $count violations ==="
  cat "$HERALD_VIOLATIONS_LOG"
}

cmd_log() {
  local lines="${1:-30}"
  tail -n "$lines" "$HERALD_DEBUG_LOG" 2>/dev/null || echo "No log file"
}

case "${1:-help}" in
  speak|play)   shift; cmd_speak "$@" ;;
  pause)        cmd_pause ;;
  resume)       cmd_resume ;;
  skip)         cmd_skip ;;
  stop)         cmd_stop ;;
  mute)         cmd_mute ;;
  status)       cmd_status ;;
  queue)        cmd_queue ;;
  next)         cmd_next ;;
  replay)       shift; cmd_replay "$@" ;;
  mode)         cmd_mode ;;
  voice)        shift; cmd_voice "$@" ;;
  ambient)      shift; cmd_ambient "$@" ;;
  recap)        cmd_recap ;;
  greeting)     cmd_greeting ;;
  notify)       cmd_notify ;;
  cleanup)      cmd_cleanup ;;
  daemon)       shift; cmd_daemon "$@" ;;
  violations)   cmd_violations ;;
  log)          shift; cmd_log "$@" ;;
  version)      echo "Herald v${VERSION}" ;;
  help|--help|-h) cmd_help ;;
  *)            echo "Unknown command: $1. Run 'herald help' for usage."; exit 1 ;;
esac
